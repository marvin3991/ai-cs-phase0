# 複製為 .env 後修改
DATABASE_URL=postgresql://rag:rag@localhost:5432/rag

# stub = 雜湊假向量,只能驗證管線會不會跑,「禁止」用於真實評測與選型
# api  = OpenAI 相容 /v1/embeddings 端點(商用 API 或自架 TEI/vLLM 皆可)
EMBEDDING_MODE=stub
EMBEDDING_DIM=1024

# EMBEDDING_MODE=api 時必填
#EMBEDDING_API_BASE=https://your-endpoint/v1
#EMBEDDING_API_KEY=
#EMBEDDING_MODEL=

# 評測集位置(預設讀上層資料夾的工作簿)
EVAL_XLSX=../評測集與知識盤點_v0.1.xlsx
